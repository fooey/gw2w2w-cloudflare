{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["CF_PAGES_COMMIT_SHA"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "/dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "ts:clean": {
      "dependsOn": ["^ts:clean"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
