{
  "$schema": "https://v2-9-5.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["CF_PAGES_COMMIT_SHA"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "ts:clean": {
      "dependsOn": ["^ts:clean"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "check-types": {
      "inputs": ["**/*.{ts,tsx}"],
      "dependsOn": ["transit"]
    },
    "format": {
      "inputs": ["**/*.{ts,tsx,md,json,mjs,mts,cjs}"]
    }
  }
}
