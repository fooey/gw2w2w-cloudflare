{
  "$schema": "https://v2-9-5.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["CI", "NODE_ENV"],
  "boundaries": {
    "tags": {
      "app": {
        "dependents": {
          "deny": ["app", "service", "library", "tooling"]
        }
      },
      "library": {
        "dependencies": {
          "deny": ["app"]
        }
      },
      "service": {
        "dependencies": {
          "deny": ["app"]
        }
      }
    }
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["CF_PAGES_COMMIT_SHA"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "ts:clean": {
      "dependsOn": ["^ts:clean"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:seed": {
      "cache": false
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "check-types": {
      "inputs": ["**/*.{ts,tsx}"],
      "dependsOn": ["transit"]
    },
    "format": {
      "inputs": ["**/*.{ts,tsx,md,json,mjs,mts,cjs}"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "src/**/*.{ts,tsx}", "vitest.config.*", "wrangler.toml"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}
