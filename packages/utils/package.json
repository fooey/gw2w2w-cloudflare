{
  "name": "@repo/utils",
  "version": "1.0.4",
  "private": true,
  "entry": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,mjs,mts,cjs}\""
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "eslint": "^10.2.0",
    "typescript": "^6"
  }
}
