{
  "name": "@repo/utils",
  "version": "2026.4.12",
  "private": true,
  "entry": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": "./src/*.ts"
  },
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,mjs,mts,cjs}\""
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
