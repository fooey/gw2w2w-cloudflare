{
  "name": "@repo/utils",
  "version": "2026.4.12",
  "private": true,
  "entry": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": "./src/*.ts"
  },
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "lint": "eslint src/",
    "check-types": "tsgo --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,mjs,mts,cjs}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
