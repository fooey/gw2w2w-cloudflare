{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "rules": {
    // Confirmed conflicts with established conventions — see conversation/commit history.
    "import/no-named-export": "off",
    "import/prefer-default-export": "off",
    "unicorn/no-null": "off",
    "no-ternary": "off",
    "no-continue": "off",
    "vitest/prefer-to-be-truthy": "off",
    "vitest/prefer-to-be-falsy": "off",
    "vitest/max-expects": "off",
    "curly": "off",
    "vitest/prefer-lowercase-title": "off",
    // oxfmt's sortImports now owns import ordering; this rule sorts by a different, conflicting
    // scheme and would fight the formatter.
    "sort-imports": "off",
    // Conflicts with the standard test-cleanup-hook pattern used throughout the suite. Also
    // directly contradicts vitest/require-hook, so at most one of the two could ever be enabled.
    "vitest/no-hooks": "off",
    // See vitest/no-hooks above — the two rules are mutually exclusive. Its only violation wasn't
    // even a real test-authoring issue.
    "vitest/require-hook": "off",
    // Conflicts with the established describe-title-matches-tested-export naming convention. Same
    // conflict as vitest/prefer-lowercase-title above.
    "vitest/prefer-describe-function-title": "off",
    // Conflicts with generic passthrough wrapper components, where prop spreading is the point.
    "react/jsx-props-no-spreading": "off",
    // The codebase's convention is nested ternaries are fine once parenthesized for clarity; this
    // rule bans nesting outright with no parens escape hatch. unicorn/no-nested-ternary enforces
    // the parens convention instead and is adopted.
    "no-nested-ternary": "off",
    // oxfmt normalizes hex literal casing on every format pass, structurally fighting this rule
    // rather than as a one-off. Same treatment as sort-imports and no-nested-ternary above.
    "unicorn/number-literal-case": "off",
    // The established custom-error-class convention already combines parameter-properties with an
    // explicit `this.name` assignment; forcing separate field declarations only adds boilerplate.
    "typescript/parameter-properties": "off",
    // Its non-guard sites (window.location.reload()) would convert safely, but most real
    // violations are typeof-window SSR-vs-client guards, where globalThis would break the check
    // (it exists on the server too) — converting only the safe subset would leave an inconsistent
    // mix within the same files.
    "unicorn/prefer-global-this": "off",
    // Directly contradicts vitest/prefer-called-times (already active via an earlier-adopted
    // category), which wants the opposite: toHaveBeenCalledTimes(1) instead of
    // toHaveBeenCalledOnce(). Both resolve to error simultaneously; the earlier rule wins.
    "vitest/prefer-called-once": "off",
    // Requires base.json's typescript/consistent-type-imports fixStyle to be
    // "separate-type-imports" (not "inline-type-imports") and no-duplicate-imports's
    // allowSeparateTypeImports: true (otherwise it fights no-duplicate-imports over splitting a
    // mixed type+value import into two statements from the same module).
    "import/consistent-type-specifier-style": ["error", "prefer-top-level"],

    // Enabled globally — each rule's few real violations carry an inline eslint-disable directive
    // at the exception site with specific reasoning, rather than disabling the rule outright.

    // Not yet reviewed — every other rule that produced real violations in the initial
    // style-category churn scan. Held off in a block so the category can be enabled
    // without a wall of unreviewed errors; re-enable individually or in small batches
    // once each has been checked against actual codebase conventions.
    "no-magic-numbers": "off",
    "sort-keys": "off",
    "id-length": "off",
    "func-style": "off",
    "import/group-exports": "off",
    "react/jsx-max-depth": "off",
    "capitalized-comments": "off",
    "vitest/prefer-expect-assertions": "off",
    "import/exports-last": "off",
    "unicorn/max-nested-calls": "off",
    "unicorn/filename-case": "off",
    "max-statements": "off",
    "vitest/no-importing-vitest-globals": "off",
    "max-params": "off",
    "init-declarations": "off",
    "vitest/require-top-level-describe": "off",
    "unicorn/catch-error-name": "off",
    "react/jsx-curly-brace-presence": "off",
    "vitest/prefer-import-in-mock": "off",
    "typescript/method-signature-style": "off"
  }
}
