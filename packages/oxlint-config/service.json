{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["./base.json"],
  "plugins": ["unicorn", "typescript", "import", "promise", "vitest", "node"],
  "rules": {
    "node/global-require": "warn",
    "node/no-exports-assign": "error"
  },
  "overrides": [
    {
      "files": ["src/index.ts"],
      "rules": {
        "import/no-default-export": "off"
      }
    }
  ]
}
