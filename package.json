{
  "name": "gw2w2w-cloudflare",
  "private": true,
  "scripts": {
    "version:all": "pnpm -r exec pnpm version",
    "deploy": "pnpm run deploy:api && pnpm run deploy:emblem && pnpm run deploy:app",
    "deploy:api": "pnpm --filter service-api run deploy",
    "deploy:emblem": "pnpm --filter service-emblem run deploy",
    "deploy:app": "pnpm --filter gw2w2w run deploy",
    "build": "turbo run build",
    "dev": "turbo dev --parallel",
    "preinstall": "npx only-allow pnpm",
    "lint": "turbo watch lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "devtools": "turbo devtools",
    "ts:clean": "turbo run ts:clean",
    "check-types": "turbo run check-types",
    "check-deps": "pnpm knip --max-show-issues 5",
    "wrangler:login": "pnpm dlx wrangler login",
    "wrangler:clean": "pnpm -r exec pnpm dlx rimraf .wrangler/state"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "knip": "^5.86.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "version": "1.0.4"
}
