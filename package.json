{
  "name": "gw2w2w-cloudflare",
  "version": "2026.4.12",
  "private": true,
  "scripts": {
    "version:all": "pnpm -r exec pnpm version",
    "deploy": "pnpm run deploy:api && pnpm run deploy:emblem && pnpm run deploy:app",
    "deploy:api": "pnpm --filter service-api run deploy",
    "deploy:emblem": "pnpm --filter service-emblem run deploy",
    "deploy:app": "pnpm --filter gw2w2w run deploy",
    "build": "turbo run build",
    "dev": "turbo run dev dev:seed",
    "preinstall": "npx only-allow pnpm",
    "lint": "turbo run lint --log-order stream",
    "lint:watch": "turbo watch lint",
    "check-types": "turbo run check-types --log-order stream",
    "check-boundaries": "turbo boundaries",
    "format": "oxfmt --config oxfmt.json .",
    "ci:format": "oxfmt --config oxfmt.json --check .",
    "ci:lint": "pnpm lint",
    "ci:lint:force": "pnpm lint --force",
    "ci:types": "pnpm check-types",
    "ci:types:force": "pnpm check-types --force",
    "ci:boundaries": "pnpm check-boundaries",
    "ci:audit": "pnpm audit",
    "ci:test": "pnpm test",
    "ci:test:force": "pnpm test --force",
    "ci:all": "pnpm ci:format && pnpm ci:lint && pnpm ci:types && pnpm ci:boundaries && pnpm ci:test && pnpm ci:audit",
    "ci:all:force": "pnpm ci:format && pnpm ci:lint:force && pnpm ci:types:force && pnpm ci:boundaries && pnpm ci:test:force && pnpm ci:audit",
    "ci:all:quiet": "pnpm ci:format && pnpm ci:lint --output-logs=errors-only && pnpm ci:types --output-logs=errors-only && pnpm ci:boundaries && pnpm ci:test --output-logs=errors-only && pnpm ci:audit",
    "ci:all:quiet-force": "pnpm ci:format && pnpm ci:lint:force --output-logs=errors-only && pnpm ci:types:force --output-logs=errors-only && pnpm ci:boundaries && pnpm ci:test:force --output-logs=errors-only && pnpm ci:audit",
    "devtools": "turbo devtools",
    "ts:clean": "turbo run ts:clean",
    "wrangler": "wrangler",
    "wrangler:login": "wrangler login",
    "wrangler:logout": "wrangler logout",
    "wrangler:relogin": "wrangler logout && wrangler login",
    "wrangler:clean": "pnpm -r exec pnpx rimraf .wrangler/state",
    "db:query": "pnpm --filter service-api run db:query",
    "setup:dev": "node scripts/setup.mjs",
    "tail": "concurrently -n \"app   ,api   ,emblem\" -c blue,green,yellow \"pnpm tail:app\" \"pnpm tail:api\" \"pnpm tail:emblem\"",
    "tail:app": "wrangler tail gw2w2w-cloudflare --format pretty",
    "tail:api": "wrangler tail service-api --format pretty",
    "tail:emblem": "wrangler tail service-emblem --format pretty",
    "update:turbo": "pnpx @turbo/codemod@latest update",
    "test": "turbo run test --log-order stream",
    "test:watch": "turbo run test:watch"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "turbo": "^2.10.5",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  },
  "engines": {
    "node": ">=26",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
