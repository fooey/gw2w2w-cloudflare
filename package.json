{
  "name": "gw2w2w-cloudflare",
  "private": true,
  "scripts": {
    "version:all": "pnpm -r exec pnpm version",
    "deploy": "pnpm run deploy:api && pnpm run deploy:emblem && pnpm run deploy:app",
    "deploy:api": "pnpm --filter service-api run deploy",
    "deploy:emblem": "pnpm --filter service-emblem run deploy",
    "deploy:app": "pnpm --filter gw2w2w run deploy",
    "build": "turbo run build",
    "dev": "turbo dev",
    "preinstall": "npx only-allow pnpm",
    "lint": "turbo watch lint",
    "check-types": "turbo check-types",
    "format": "turbo format",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,mjs,mts,cjs}\"",
    "devtools": "turbo devtools",
    "ts:clean": "turbo run ts:clean",
    "wrangler:login": "pnpm dlx wrangler login",
    "wrangler:clean": "pnpm -r exec pnpm dlx rimraf .wrangler/state",
    "update:turbo": "pnpm dlx @turbo/codemod@latest update"
  },
  "devDependencies": {
    "@types/node": "^24",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.5",
    "typescript": "^6",
    "wrangler": "^4.80.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "version": "1.0.4"
}
